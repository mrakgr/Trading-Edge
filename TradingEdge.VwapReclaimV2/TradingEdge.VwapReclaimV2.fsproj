<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <!-- VwapReclaimV2: fork of VwapReclaim (SMB VWAP x 9-EMA reclaim scalp, long-only).
       Forked 2026-07-11 to revise the FEATURE SET with the experience gained on
       BreakoutTimer + MaxFlyerV3. V1 stays intact on main as the settled baseline.
       Same two-pipeline architecture: pipeline 1 = SELECT from mr_candidate;
       pipeline 2 = the intraday 1m engine (Intraday.fs). Self-contained (reads
       trading.db + minute_aggs parquets). -->
  <ItemGroup>
    <Compile Include="Intraday.fs" />
    <Compile Include="Backtest.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../TradingEdge.RollingMa/TradingEdge.RollingMa.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Argu" Version="6.2.5" />
    <PackageReference Include="DuckDB.NET.Data.Full" Version="1.4.4" />
    <PackageReference Include="Nito.Collections.Deque" Version="1.2.1" />
  </ItemGroup>

</Project>
