    <TargetFramework>net10.0</TargetFramework>
    <RollForward>LatestMajor</RollForward>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Dbn.fs" />
    <Compile Include="MboReader.fs" />
    <Compile Include="Trades.fs" />
    <Compile Include="Bars.fs" />
