    <Compile Include="Snapshots.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Control.TaskSeq" Version="*" />
    <PackageReference Include="ZstdSharp.Port" Version="0.8.*" />
  </ItemGroup>

</Project>
